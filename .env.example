# Site URL (sitemap / RSS / Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string

# Admin credentials (plaintext password for local/dev)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Prefer bcrypt hash in production (overrides ADMIN_PASSWORD if set):
#   node -e "require('bcryptjs').hash('your-password',10).then(console.log)"
# ADMIN_PASSWORD_HASH=

# --- GitHub content backend (required on Vercel to create/edit/delete posts) ---
# Classic PAT: repo scope  |  Fine-grained: Contents Read/Write on this repo
# GITHUB_TOKEN=ghp_xxxxxxxx
# GITHUB_REPO=xiaoqianran/Web001-Blog
# GITHUB_BRANCH=main

# --- Giscus comments (optional, https://giscus.app ) ---
# NEXT_PUBLIC_GISCUS_REPO=xiaoqianran/Web001-Blog
# NEXT_PUBLIC_GISCUS_REPO_ID=
# NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
# NEXT_PUBLIC_GISCUS_CATEGORY_ID=
